@{
    ViewData["Title"] = "Login";
}

@section Styles {
    <style>
        .page-inner--login {
            position: relative;
        }

        .page-inner--login .page-header__lead {
            max-width: 760px;
            color: #5b4f42;
        }

        .login-page {
            padding: 2rem 0 4rem;
        }

        .login-card {
            background: linear-gradient(155deg, rgba(255, 255, 255, 0.93), rgba(255, 250, 242, 0.88));
            border: 1px solid rgba(191, 161, 106, 0.25);
            border-radius: 1.25rem;
            box-shadow: 0 20px 44px rgba(15, 23, 42, 0.12);
            overflow: hidden;
        }

        .login-card__head {
            padding: 1.25rem 1.5rem 0.35rem;
        }

        .login-card__title {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            color: #0f172a;
            text-align: center;
        }

        .login-card__body {
            padding: 1rem 1.5rem 1.5rem;
        }

        .login-card .form-label {
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            font-weight: 600;
        }

        .login-card .form-control {
            border-radius: 0.75rem;
            border: 1px solid rgba(148, 163, 184, 0.36);
            background: rgba(255, 255, 255, 0.88);
            min-height: 46px;
        }

        .login-card .form-control:focus {
            border-color: rgba(191, 161, 106, 0.6);
            box-shadow: 0 0 0 0.2rem rgba(245, 158, 11, 0.14);
        }

        .btn-login {
            min-height: 46px;
            border-radius: 0.85rem;
            border: none;
            font-weight: 700;
            color: #1f2937;
            background: linear-gradient(135deg, #fde68a 0%, #fcd34d 50%, #f59e0b 100%);
            box-shadow: 0 12px 24px rgba(245, 158, 11, 0.3);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 28px rgba(245, 158, 11, 0.35);
            color: #111827;
        }

        .login-alert p {
            margin-bottom: 0.35rem;
        }
    </style>
}

<div class="page-inner page-inner--login">
    <header class="page-header">
        <div class="container">
            <p class="page-header__label">Admin</p>
            <h1 class="page-header__title">Login</h1>
            <p class="page-header__lead">Secure access for managing portfolio content, reviews, and administrative actions.</p>
        </div>
    </header>

    <div class="container login-page">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="login-card">
                    <div class="login-card__head">
                        <h2 class="login-card__title">Welcome Back</h2>
                    </div>
                    <div class="login-card__body">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger login-alert">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <p>@error.ErrorMessage</p>
                                }
                            </div>
                        }
                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" name="email" required>
                            </div>
                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <input type="password" class="form-control" id="password" name="password" required>
                            </div>
                            <div class="d-grid">
                                <button type="submit" class="btn btn-login">Login</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div> 