        <section class="band band--catalogue" id="contact">
            <div class="catalog-stack catalog-stack--wide">
                <header class="catalog-section-head">
                    <p class="section-kicker">Enquiries</p>
                    <h2 class="section-title">Contact</h2>
                </header>
                <div class="catalog-panel catalog-panel--contact">
                    <p class="catalog-lead">Commission and catalogue enquiries. This form is part of the demo only — it does not transmit mail or store data.</p>
                    <form class="demo-contact" action="#" method="post" aria-label="Demo enquiry form">
                        <p class="demo-contact__hint" id="demoFormNote">Demonstration UI only — nothing leaves this page.</p>
                        <div>
                            <label for="demoName">Name</label>
                            <input id="demoName" name="name" type="text" autocomplete="off" aria-describedby="demoFormNote" />
                        </div>
                        <div>
                            <label for="demoEmail">Email</label>
                            <input id="demoEmail" name="email" type="email" autocomplete="off" aria-describedby="demoFormNote" />
                        </div>
                        <div>
                            <label for="demoMsg">Message</label>
