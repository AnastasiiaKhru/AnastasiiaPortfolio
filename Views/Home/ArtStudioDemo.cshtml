            </article>

            <article class="cluster cluster--mosaic">
                <h3 class="cluster__label">Paper · ink · ash</h3>
                <div class="cluster__grid cluster__grid--mosaic">
                    <figure class="gcell gcell--wide">
                        <img class="art-img" src="/images/alisa-gallery/08.jpg" alt="Paintings on wall, panoramic" width="1200" height="800" loading="lazy" />
