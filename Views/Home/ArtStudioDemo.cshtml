    <footer class="site-footer">
        <p class="site-footer__line">By Alisa Khru · gallery demo</p>
        <p class="site-footer__line">Museum catalogue layout</p>
    </footer>

    <script>
    (function () {
        var overlay = document.getElementById('menuOverlay');
        var openBtn = document.getElementById('menuOpen');
        var closeBtn = document.getElementById('menuClose');
        var heroSection = document.getElementById('heroIntro');
        var heroInner = document.getElementById('heroInner');
        var heroGlow = document.getElementById('heroCursorGlow');
        var heroMenuBtn = document.getElementById('heroMenuBtn');
        if (!overlay || !openBtn || !closeBtn) return;

        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function scrollToSectionId(id) {
            var smooth = reducedMotion ? 'auto' : 'smooth';
            if (id === 'top') {
                window.scrollTo({ top: 0, behavior: smooth });
                return;
            }
            var target = document.getElementById(id);
            if (target) target.scrollIntoView({ behavior: smooth, block: 'start' });
            else window.location.hash = '#' + id;
        }

        function openMenu() {
            overlay.removeAttribute('hidden');
            overlay.classList.add('is-open');
            document.body.classList.add('menu-lock');
            openBtn.setAttribute('aria-expanded', 'true');
            closeBtn.focus();
        }

        function closeMenu(returnFocusToMenuBtn) {
            var refocus = returnFocusToMenuBtn !== false;
            overlay.classList.remove('is-open');
            document.body.classList.remove('menu-lock');
            openBtn.setAttribute('aria-expanded', 'false');
            window.setTimeout(function () {
                overlay.setAttribute('hidden', '');
                if (refocus) openBtn.focus();
            }, 350);
        }

        openBtn.addEventListener('click', openMenu);
        closeBtn.addEventListener('click', function () { closeMenu(true); });
        if (heroMenuBtn) {
            heroMenuBtn.addEventListener('click', function () { openMenu(); });
        }
        overlay.addEventListener('click', function (e) {
            if (e.target === overlay) closeMenu(true);
        });

        overlay.querySelectorAll('nav a').forEach(function (a) {
            a.addEventListener('click', function (e) {
                var href = a.getAttribute('href') || '';
                if (href.charAt(0) !== '#' || href.length < 2) return;
                e.preventDefault();
                var id = href.slice(1);
                closeMenu(false);
                window.requestAnimationFrame(function () { scrollToSectionId(id); });
            });
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeMenu(true);
        });

        function bindInPageAnchor(el) {
            if (!el) return;
            el.addEventListener('click', function (e) {
                var href = el.getAttribute('href') || '';
                if (href.charAt(0) !== '#' || href.length < 2) return;
                e.preventDefault();
                var id = href.slice(1);
                if (overlay.classList.contains('is-open')) closeMenu(false);
                window.requestAnimationFrame(function () { scrollToSectionId(id); });
            });
        }

        bindInPageAnchor(document.querySelector('.top-logo'));
        document.querySelectorAll('.top-actions a[href^="#"]').forEach(bindInPageAnchor);
        document.querySelectorAll('.catalog-cta[href^="#"], footer a[href^="#"], .hero__btn[href^="#"]').forEach(bindInPageAnchor);
        bindInPageAnchor(document.querySelector('a.hero__scroll'));
        if (heroSection && heroInner && heroGlow && !reducedMotion) {
            var rafId;
            heroSection.addEventListener('mousemove', function (e) {
                var rect = heroSection.getBoundingClientRect();
                var x = e.clientX - rect.left;
                var y = e.clientY - rect.top;
                var px = (x / rect.width) - 0.5;
                var py = (y / rect.height) - 0.5;
                if (rafId) cancelAnimationFrame(rafId);
                rafId = requestAnimationFrame(function () {
                    heroInner.style.transform = 'translate3d(' + (px * 10).toFixed(2) + 'px, ' + (py * 8).toFixed(2) + 'px, 0)';
                    heroGlow.style.left = x.toFixed(1) + 'px';
                    heroGlow.style.top = y.toFixed(1) + 'px';
                });
            });
            heroSection.addEventListener('mouseleave', function () {
                heroInner.style.transform = 'translate3d(0,0,0)';
                heroGlow.style.opacity = '0';
            });
            heroSection.addEventListener('mouseenter', function () {
                heroGlow.style.opacity = '1';
            });
        }

        var slides = document.querySelectorAll('.carousel-row__slide');
        var dotsWrap = document.getElementById('carDots');
        var carPrev = document.getElementById('carPrev');
        var carNext = document.getElementById('carNext');
        var idx = 0;

        function show(i) {
            if (!slides.length) return;
            idx = (i + slides.length) % slides.length;
            slides.forEach(function (s, j) { s.classList.toggle('is-on', j === idx); });
            if (dotsWrap) {
                dotsWrap.querySelectorAll('button').forEach(function (d, j) {
                    d.classList.toggle('on', j === idx);
                    d.setAttribute('aria-selected', j === idx ? 'true' : 'false');
                });
            }
        }

        if (dotsWrap && slides.length) {
            slides.forEach(function (_, i) {
                var b = document.createElement('button');
                b.type = 'button';
                b.setAttribute('aria-label', 'Slide ' + (i + 1));
                b.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
                b.setAttribute('role', 'tab');
                b.addEventListener('click', function () { show(i); resetCar(); });
                if (i === 0) b.classList.add('on');
                dotsWrap.appendChild(b);
            });
        }

        if (carPrev) carPrev.addEventListener('click', function () { show(idx - 1); resetCar(); });
        if (carNext) carNext.addEventListener('click', function () { show(idx + 1); resetCar(); });

        var carTimer;
        function resetCar() {
            clearInterval(carTimer);
            if (!reducedMotion && slides.length) carTimer = setInterval(function () { show(idx + 1); }, 7000);
        }
        resetCar();

        var demoForm = document.querySelector('.demo-contact');
        var demoBtn = document.getElementById('demoSendBtn');
        if (demoForm) {
            demoForm.addEventListener('submit', function (e) { e.preventDefault(); });
        }
        if (demoBtn) {
            demoBtn.addEventListener('click', function () {
                var t = demoBtn.textContent;
                demoBtn.textContent = 'Demo only — not sent';
                demoBtn.disabled = true;
                window.setTimeout(function () {
                    demoBtn.textContent = t;
                    demoBtn.disabled = false;
                }, 2200);
            });
        }
    })();
    </script>
</body>
</html>
