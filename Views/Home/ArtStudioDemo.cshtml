            <div class="carousel-section">
                <div class="carousel-row" id="featuredCarousel" role="region" aria-label="Featured installation views">
                    <div class="carousel-row__slide is-on">
                        <img class="art-img" src="/images/alisa-gallery/02.jpg" alt="Gallery salon — wide view" width="1600" height="685" fetchpriority="high" />
                        <div class="carousel-row__cap">Carousel · selected works</div>
                    </div>
                    <div class="carousel-row__slide">
                        <img class="art-img" src="/images/alisa-gallery/08.jpg" alt="Wall sequence" width="1600" height="685" loading="lazy" />
                        <div class="carousel-row__cap">Wall sequence</div>
                    </div>
                    <div class="carousel-row__slide">
                        <img class="art-img" src="/images/alisa-gallery/05.jpg" alt="Abstract interval" width="1600" height="685" loading="lazy" />
                        <div class="carousel-row__cap">Interval</div>
                    </div>
                </div>
                <div class="carousel-row__controls">
                    <button type="button" id="carPrev">Previous</button>
                    <button type="button" id="carNext">Next</button>
                    <div class="carousel-row__dots" id="carDots" role="tablist" aria-label="Slides"></div>
                </div>
            </div>
