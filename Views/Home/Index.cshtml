@model AnastasiiaPortfolio.Models.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <style>
        /* Modern premium hero */

        .hero-section {
            padding: clamp(0.9rem, 2vh, 1.5rem) 0;
            margin-bottom: 0;
            position: relative;
            min-height: calc(100vh - 64px);
            display: flex;
            align-items: center;
            overflow: hidden;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.55), rgba(248, 250, 252, 0.35)),
                radial-gradient(circle at 16% 20%, rgba(251, 191, 36, 0.1), transparent 42%),
                radial-gradient(circle at 86% 15%, rgba(251, 146, 60, 0.08), transparent 38%),
                url('/images/hero-home-bg.png');
            background-size: auto, auto, auto, cover;
            background-position: center, 16% 20%, 86% 15%, center;
            background-repeat: no-repeat;
        }

        .hero-section::after {
            content: '';
            position: absolute;
            inset: auto -120px -110px auto;
            width: 420px;
            height: 420px;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.28), rgba(99, 102, 241, 0));
            filter: blur(16px);
            z-index: 1;
            pointer-events: none;
        }

        .hero-section::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 20% 24%, rgba(251, 191, 36, 0.06), transparent 45%),
                linear-gradient(112deg, rgba(248, 250, 252, 0.36), rgba(241, 245, 249, 0.2));
            backdrop-filter: blur(2px);
            pointer-events: none;
            z-index: 1;
        }

        .hero-section .container {
            position: relative;
            z-index: 2;
            background: rgba(255, 255, 255, 0.62);
            border-radius: 32px;
            border: 1px solid rgba(255, 255, 255, 0.56);
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.16), 0 0 0 1px rgba(255, 255, 255, 0.55) inset;
            backdrop-filter: blur(18px);
            padding: clamp(1.1rem, 1.8vw, 2rem);
        }

        .hero-kicker {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.35rem 0.9rem;
            border-radius: 999px;
            color: #0f172a;
            border: 1px solid rgba(191, 161, 106, 0.45);
            background: rgba(255, 250, 240, 0.78);
            font-size: 0.85rem;
            margin-bottom: 0.9rem;
            animation: heroFadeUp 0.7s ease both;
        }

        .hero-section .display-4 {
            font-size: clamp(2rem, 1.4rem + 2.4vw, 3.3rem);
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.04em;
            margin-bottom: 1rem;
            text-shadow: 0 8px 20px rgba(148, 163, 184, 0.22);
            animation: heroFadeUp 0.8s ease 0.08s both;
        }

        .hero-section .lead {
            font-size: var(--font-size-lg);
            color: #1e293b;
            line-height: 1.72;
            max-width: 560px;
            text-shadow: none;
            animation: heroFadeUp 0.85s ease 0.14s both;
        }

        .hero-image {
            position: relative;
            overflow: visible;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .hero-portrait {
            position: relative;
            width: min(360px, 88%);
            border-radius: 30px;
            overflow: hidden;
            aspect-ratio: 4/5;
            border: 1px solid rgba(255, 255, 255, 0.35);
            box-shadow: 0 30px 70px -20px rgba(2, 6, 23, 0.88), 0 0 0 1px rgba(255, 255, 255, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.2);
            transform: perspective(1100px) rotateY(-8deg) rotateX(2deg);
            transition: transform 0.4s ease, box-shadow 0.4s ease;
            background: linear-gradient(180deg, #f8fafc, #e2e8f0);
            animation: heroFadeUp 0.9s ease 0.22s both;
        }

        .hero-portrait:hover {
            transform: perspective(1100px) rotateY(-3deg) rotateX(0deg) translateY(-2px);
            box-shadow: 0 38px 92px -16px rgba(2, 6, 23, 0.95), 0 0 0 1px rgba(125, 211, 252, 0.45), inset 0 1px 0 rgba(255, 255, 255, 0.26);
        }

        .hero-portrait::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(15, 23, 42, 0) 55%, rgba(15, 23, 42, 0.2) 100%);
            pointer-events: none;
            z-index: 1;
        }

        .hero-portrait img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center 26%;
            display: block;
        }

        .hero-portrait-glow {
            position: absolute;
            inset: auto -25% -20% auto;
            width: 75%;
            aspect-ratio: 1/1;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(245, 158, 11, 0.24), rgba(245, 158, 11, 0));
            filter: blur(12px);
            pointer-events: none;
            z-index: -1;
            animation: heroGlowPulse 4s ease-in-out infinite;
        }

        .hero-section .hero-btn-group {
            margin-top: 1.1rem;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.65rem;
            animation: heroFadeUp 0.95s ease 0.28s both;
        }

        .hero-section .hero-btn-group .btn,
        .hero-section .social-link {
            min-height: 44px;
            border-radius: 0.85rem;
            font-size: 0.95rem;
            transition: transform .2s ease, box-shadow .2s ease, background .2s ease, border-color .2s ease;
        }

        .hero-section .social-link {
            grid-column: 1 / -1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .45rem;
        }

        .hero-section .hero-btn-group .btn-primary {
            background: linear-gradient(135deg, #fde68a 0%, #fcd34d 45%, #f59e0b 100%);
            color: #1f2937;
            border: none;
            box-shadow: 0 14px 26px rgba(245, 158, 11, 0.32);
        }
        .hero-section .hero-btn-group .btn-primary:hover {
            background: linear-gradient(135deg, #fef3c7 0%, #fcd34d 55%, #f59e0b 100%);
            color: #111827;
            transform: translateY(-2px);
        }
        .hero-section .hero-btn-group .btn-outline-primary {
            background: rgba(255, 255, 255, 0.72);
            color: #0f172a;
            border: 1px solid rgba(148, 163, 184, 0.45);
        }
        .hero-section .hero-btn-group .btn-outline-primary:hover {
            background: rgba(255, 248, 230, 0.95);
            color: #020617;
            border-color: rgba(191, 161, 106, 0.56);
        }
        .hero-section .hero-btn-group .btn-secondary {
            background: rgba(255, 255, 255, 0.72);
            color: #0f172a;
            border: 1px solid rgba(148, 163, 184, 0.45);
        }
        .hero-section .hero-btn-group .btn-secondary:hover {
            background: rgba(255, 248, 230, 0.95);
            color: #020617;
            border-color: rgba(191, 161, 106, 0.56);
        }
        .hero-section .social-link {
            background: rgba(255, 255, 255, 0.72);
            color: #0f172a;
            border: 1px solid rgba(148, 163, 184, 0.5);
        }
        .hero-section .social-link:hover {
            background: rgba(255, 248, 230, 0.95);
            color: #020617;
            border-color: rgba(191, 161, 106, 0.56);
            transform: translateY(-2px);
        }

        @@keyframes heroFadeUp {
            from {
                opacity: 0;
                transform: translateY(14px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes heroGlowPulse {
            0%, 100% { opacity: .75; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.08); }
        }

        @@media (min-width: 769px) {
            .hero-section .row {
                --bs-gutter-x: 1.1rem;
            }
        }

        @@media (max-width: 1200px) and (min-width: 769px) {
            .hero-section {
                min-height: auto;
                padding: 1rem 0;
            }
            .hero-section .container {
                padding: 1.05rem;
                border-radius: 20px;
            }
            .hero-section .row {
                row-gap: 0.9rem;
                justify-content: center;
            }
            .hero-section .col-md-7,
            .hero-section .col-md-5 {
                flex: 0 0 100%;
                max-width: 100%;
            }
            .hero-section .col-md-7 {
                text-align: center;
            }
            .hero-kicker {
                margin-left: auto;
                margin-right: auto;
            }
            .hero-section .display-4 {
                font-size: clamp(1.7rem, 1.1rem + 1.35vw, 2.2rem);
                margin-bottom: 0.65rem;
                margin-left: auto;
                margin-right: auto;
                max-width: 22ch;
            }
            .hero-section .lead {
                font-size: 0.98rem;
                line-height: 1.55;
                max-width: 58ch;
                margin-left: auto;
                margin-right: auto;
            }
            .hero-section .hero-btn-group {
                margin-top: 0.75rem;
                gap: 0.55rem;
                grid-template-columns: 1fr;
                max-width: 700px;
                margin-left: auto;
                margin-right: auto;
            }
            .hero-image {
                max-width: 260px;
                margin: 0.35rem auto 0;
            }
            .hero-portrait {
                width: 100%;
            }
            .hero-section .social-link {
                grid-column: auto;
            }
            .hero-section .hero-btn-group .btn,
            .hero-section .social-link {
                max-width: 700px;
            }
        }

        @@media (max-width: 768px) {
            .hero-section { min-height: auto; padding: var(--spacing-6) 0; }
            .hero-section .container { padding: var(--spacing-5) var(--spacing-4); }
            .hero-section .display-4 { font-size: clamp(1.5rem, 4vw, 2rem); }
            .hero-section .lead { font-size: var(--font-size-base); }
            .hero-image { max-width: 270px; margin: 0.5rem auto 0; }
            .hero-portrait,
            .hero-portrait:hover { transform: none; }
            .hero-section .hero-btn-group {
                grid-template-columns: 1fr;
            }
            .hero-section .social-link {
                grid-column: auto;
            }
        }

        @@media (max-height: 820px) and (min-width: 769px) {
            .hero-section {
                min-height: auto;
                padding: .75rem 0;
            }
            .hero-section .container {
                padding: 1rem;
            }
            .hero-section .display-4 {
                font-size: clamp(1.8rem, 1.2rem + 1.8vw, 2.7rem);
                margin-bottom: .6rem;
            }
            .hero-section .lead {
                margin-bottom: .55rem;
                line-height: 1.58;
            }
            .hero-portrait {
                width: min(300px, 82%);
            }
        }
    </style>
}

<div id="home" class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7 col-md-7 order-lg-1">
                <div class="hero-kicker">Portfolio 2026</div>
                <h1 class="display-4">Building elegant digital experiences that perform.</h1>
                <p class="lead">Transforming complex ideas into elegant, high-performance web solutions.</p>
                <p class="lead mb-0">Full-stack developer with 5+ years of experience and a foundation in customer service, operations, and management.</p>
                <div class="hero-btn-group">
                    <a asp-controller="Home" asp-action="Projects" class="btn btn-primary">
                        <i class="fas fa-code"></i>View My Work
                    </a>
                    <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-primary">
                        <i class="fas fa-envelope"></i>Contact Me
                    </a>
                    <a asp-action="DownloadResume" asp-controller="Home" class="btn btn-secondary" target="_blank" rel="noopener">
                        <i class="fas fa-file-pdf"></i>View Resume
                    </a>
                    <a asp-action="DownloadReferences" asp-controller="Home" class="btn btn-secondary" target="_blank" rel="noopener">
                        <i class="fas fa-file-pdf"></i>View References
                    </a>
                    <a href="https://www.linkedin.com/in/anastasiia-khrustaleva-29a180100/" target="_blank" rel="noopener" class="social-link">
                        <i class="fab fa-linkedin"></i>Connect on LinkedIn
                    </a>
                </div>
            </div>
            <div class="col-lg-5 col-md-5 order-lg-2 mt-3 mt-md-0">
                <div class="hero-image">
                    <div class="hero-portrait" role="img" aria-label="Portrait photo of Anastasiia">
                        <img src="/images/hero-image.png" alt="Anastasiia portrait photo">
                    </div>
                    <div class="hero-portrait-glow" aria-hidden="true"></div>
                </div>
            </div>
        </div>
    </div>
</div>
